FROM node:20-alpine AS frontend-build
WORKDIR /app

COPY frontend/package*.json ./frontend/
WORKDIR /app/frontend
RUN npm ci

COPY frontend/ ./
WORKDIR /app
COPY package*.json ./
COPY build.js ./
COPY content ./content
COPY src ./src
RUN mkdir -p frontend/public && node build.js
WORKDIR /app/frontend
RUN npm run build

FROM node:20-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=5288
ENV LISTEN_HOST=0.0.0.0

COPY package*.json ./
RUN npm ci --omit=dev

RUN mkdir -p /app/logs /app/data-export /app/frontend/public /app/frontend/dist

COPY public ./public
COPY server.js ./server.js
COPY content ./content
COPY src ./src
COPY frontend ./frontend
COPY --from=frontend-build /app/frontend/dist ./frontend/dist
COPY --from=frontend-build /app/frontend/public/generated-data.json ./frontend/public/generated-data.json
COPY --from=frontend-build /app/src/generated-data.js ./src/generated-data.js

EXPOSE 5288
CMD ["node", "server.js"]
